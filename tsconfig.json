{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals"]
  },
  "include": [
    "entrypoints/popup/**/*.ts",
    "entrypoints/popup/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "wxt.config.ts"
  ]
}

{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "app:run",
      "type": "shell",
      "command": "pnpm dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [{ "regexp": "." }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Listening|ready in"
        }
      }
    },
    {
      "label": "test:run",
      "type": "shell",
      "command": "pnpm test"
    },
    {
      "label": "test:watch",
      "type": "shell",
      "command": "pnpm test:watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [{ "regexp": "." }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Watching for file changes|PASS|FAIL"
        }
      }
    }
  ]
}
